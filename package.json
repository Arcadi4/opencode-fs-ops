{
  "name": "opencode-fs-ops",
  "version": "0.1.0",
  "description": "OpenCode plugin that adds permission-gated `mv` and `cp` filesystem tools, encouraging agents to move/copy existing files instead of rewriting them.",
  "homepage": "https://github.com/Arcadi4/opencode-fs-ops#readme",
  "bugs": {
    "url": "https://github.com/Arcadi4/opencode-fs-ops/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arcadi4/opencode-fs-ops.git"
  },
  "license": "MIT",
  "author": "4rcadia",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "filesystem",
    "mv",
    "cp",
    "tool"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm build"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.15.7"
  }
}
